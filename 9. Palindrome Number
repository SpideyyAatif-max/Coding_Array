bool isPalindrome(int x) {

        if(x < 0) return false;

        int arr[10];
        int n = 0;

        while(x != 0){
            arr[n] = x % 10;
            x /= 10;
            n++;
        }

        int left = 0;
        int right = n - 1;

        while(left < right){
            if(arr[left] != arr[right]){
                return false;
            }
            left++;
            right--;
        }

        return true;
    }
