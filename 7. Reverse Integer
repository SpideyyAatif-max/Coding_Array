class Solution {
public:
    int reverse(int x) {
        int array[10];
        int i = 0;
        while(x != 0)
        {
            array[i] = x % 10;
            i++;
            x = x / 10;
        }
        int result = 0;
        for(int j = 0; j < i; j++)
        {
            if(result > INT_MAX/10 || result < INT_MIN/10)
                return 0;
            result = result * 10 + array[j];
        }
        return result;
    }
};
